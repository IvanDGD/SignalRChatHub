@{
    ViewData["Title"] = "Создать голосование";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <h3 class="mb-4">📝 Создать голосование</h3>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@err.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label fw-semibold">Вопрос</label>
                <input type="text" name="name" class="form-control" required
                       placeholder="Например: Какой ваш любимый цвет?" maxlength="200" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Варианты ответа</label>
                <div id="options-container">
                    <input type="text" name="options" class="form-control mb-2" placeholder="Вариант 1" required />
                    <input type="text" name="options" class="form-control mb-2" placeholder="Вариант 2" required />
                </div>
                <button type="button" class="btn btn-sm btn-outline-secondary mt-1" onclick="addOption()">
                    + Добавить вариант
                </button>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Создать</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        let count = 2;
        function addOption() {
            count++;
            const container = document.getElementById("options-container");
            const input = document.createElement("input");
            input.type = "text";
            input.name = "options";
            input.className = "form-control mb-2";
            input.placeholder = "Вариант " + count;
            container.appendChild(input);
        }
    </script>
}
